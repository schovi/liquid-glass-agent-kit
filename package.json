{
  "name": "liquid-glass-agent-kit",
  "version": "0.1.0",
  "private": true,
  "description": "Spec-first kit for Apple-inspired Liquid Glass web UI: canonical tokens, a portable skill, a single shared Codex/Claude plugin, and a heuristic auditor.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "example:web":          "node scripts/serve.mjs",
    "example:native":       "examples/macos-native-swift/scripts/run.sh",
    "example:native:build": "examples/macos-native-swift/scripts/build.sh",
    "example:native:xcode": "examples/macos-native-swift/scripts/xcode.sh",
    "example:native:clean": "examples/macos-native-swift/scripts/clean.sh",
    "audit:examples":       "node plugins/liquid-glass-web/skills/liquid-glass-web-ui/scripts/audit-liquid-glass-html.mjs examples/macos-web",
    "validate":             "npm run audit:examples"
  },
  "engines": { "node": ">=18" }
}
