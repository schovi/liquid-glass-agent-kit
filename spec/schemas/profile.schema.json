{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liquid-glass-agent-kit.example/schemas/profile.schema.json",
  "title": "Liquid Glass Profile",
  "type": "object",
  "required": ["profile", "version", "status", "renderers", "variants", "surfaces"],
  "properties": {
    "profile":  { "type": "string" },
    "version":  { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "status":   { "type": "string" },
    "sources":  { "type": "object" },
    "imports":  { "type": "array", "items": { "type": "string" } },
    "renderers": {
      "type": "object",
      "required": ["css", "css-svg", "webgl"],
      "additionalProperties": false,
      "properties": {
        "css":     { "$ref": "#/$defs/renderer" },
        "css-svg": { "$ref": "#/$defs/renderer" },
        "webgl":   { "$ref": "#/$defs/renderer" }
      }
    },
    "variants": {
      "type": "object",
      "required": ["regular", "clear"],
      "additionalProperties": false,
      "properties": {
        "regular": { "$ref": "#/$defs/variant" },
        "clear":   { "$ref": "#/$defs/variant" }
      }
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "renderer": {
      "type": "object",
      "required": ["description", "when"],
      "properties": {
        "description": { "type": "string" },
        "when":        { "type": "string" }
      }
    },
    "variant": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "description": { "type": "string" }
      }
    }
  }
}
